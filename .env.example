# PDF2Searchable 配置
# 复制为 .env 并修改

# 服务端口
BACKEND_PORT=8000

# OCR 服务地址（153 算力服务器）
PADDLEOCR_URL=http://10.19.26.153:8080
MINERU_URL=http://10.19.26.153:8000

# 超时配置（秒）
PADDLEOCR_TIMEOUT=120
MINERU_TIMEOUT=120

# 上传文件大小限制（MB）
MAX_UPLOAD_SIZE_MB=100

# 批处理配置
BATCH_POLL_INTERVAL=5
BATCH_MAX_CONCURRENT=2

# 数据库路径（本地相对路径，Docker 部署在 docker-compose.yml 中覆盖）
DATABASE_PATH=./data/jobs.db

# 上传临时目录
UPLOAD_DIR=./uploads

# 日志级别
LOG_LEVEL=INFO
